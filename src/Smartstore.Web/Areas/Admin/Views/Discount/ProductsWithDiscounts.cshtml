@using Smartstore.Admin.Models.Discounts
@model ProductWithDiscountModel

<datagrid id="products-with-discounts-grid"
          allow-resize="true"
          allow-row-selection="false"
          preserve-grid-state="true" 
          preserve-command-state="true"
          allow-column-reordering="true">
    <datasource read="@Url.Action("GetProductsWithDiscounts")" />
    <paging position="Bottom" page-index="1" show-size-chooser="true" />
    <sorting allow-unsort="true" allow-multisort="false">
        <sort by="ProductName" />
    </sorting>
    <columns>
        <column for="ProductName" hideable="false" />
        <column for="DiscountName" hideable="false" />
        <column for="StartDate" width="auto" halign="center" />
        <column for="EndDate" width="auto" halign="center" />
        <column for="DiscountPercentage" width="auto" halign="center" />
        <column for="DiscountAmount" width="auto" halign="center" />
    </columns>
</datagrid>