@model IEnumerable<DiscountModel>

<div class="table-responsive">
    <table class="table table-hover table-striped" id="discounts-grid">
        <thead>
            <tr>
                <th>@T("Admin.Promotions.Discounts.Fields.Name")</th>
                <th>@T("Admin.Promotions.Discounts.Fields.DiscountType")</th>
                <th>@T("Admin.Promotions.Discounts.Fields.DiscountAmount")</th>
                <th>@T("Admin.Promotions.Discounts.Fields.StartDate")</th>
                <th>@T("Admin.Promotions.Discounts.Fields.EndDate")</th>
                <th>@T("Admin.Promotions.Discounts.Fields.RequiresCouponCode")</th>
                <th>@T("Admin.Common.Actions")</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var discount in Model)
            {
                <tr>
                    <td>
                        <a href="@discount.EditUrl">@discount.Name</a>
                    </td>
                    <td>@discount.DiscountTypeName</td>
                    <td>
                        @if (discount.UsePercentage)
                        {
                            @discount.FormattedDiscountPercentage
                        }
                        else
                        {
                            @discount.FormattedDiscountAmount
                        }
                    </td>
                    <td>@discount.StartDate</td>
                    <td>@discount.EndDate</td>
                    <td>
                        <i class="fa @(discount.RequiresCouponCode ? "fa-check" : "fa-times")"></i>
                    </td>
                    <td>
                        <a href="@discount.EditUrl" class="btn btn-sm btn-secondary">
                            <i class="fa fa-pencil-alt"></i>
                        </a>
                        <a href="#" class="btn btn-sm btn-danger delete-discount" data-id="@discount.Id">
                            <i class="fa fa-trash"></i>
                        </a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>