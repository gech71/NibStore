@model ManageDiscountsViewModel

<ul class="nav nav-tabs" id="discountTabs" role="tablist">
    <li class="nav-item" role="presentation">
        <button class="nav-link active" id="discounts-tab" data-bs-toggle="tab" data-bs-target="#discounts" type="button" role="tab">
            @T("Admin.Promotions.Discounts")
        </button>
    </li>
    <li class="nav-item" role="presentation">
        <button class="nav-link" id="apply-tab" data-bs-toggle="tab" data-bs-target="#apply" type="button" role="tab">
            @T("Admin.Promotions.Discounts.ApplyDiscount")
        </button>
    </li>
    <li class="nav-item" role="presentation">
        <button class="nav-link" id="productswith-tab" data-bs-toggle="tab" data-bs-target="#productswith" type="button" role="tab">
            @T("Admin.Promotions.Discounts.ProductsWithDiscounts")
        </button>
    </li>
</ul>

<div class="tab-content mt-3" id="discountTabsContent">
    <div class="tab-pane fade show active" id="discounts" role="tabpanel">
        <partial name="_Grid.Discounts" model="Model.DiscountModel" />
    </div>
    <div class="tab-pane fade" id="apply" role="tabpanel">
        <partial name="DiscountProductList" model="Model.DiscountProductListModel" />
    </div>
    <div class="tab-pane fade" id="productswith" role="tabpanel">
        <partial name="ProductsWithDiscounts" model="Model.ProductsWithDiscounts" />
    </div>
</div>