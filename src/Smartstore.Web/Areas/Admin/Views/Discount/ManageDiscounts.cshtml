@using Smartstore.Admin.Models.Discounts
@model YourNamespace.Models.DiscountModel
@{
    ViewBag.Title = T("Admin.Promotions.ManageDiscounts").Value;
    Assets.BodyAttributes.AppendCssClass("spa-layout");
}

<div class="section-header">
    <div class="title">
        <i class="fa fa-signal fa-flip-horizontal"></i>
        @T("Admin.Promotions.ManageDiscounts")
    </div>
</div>

<ul class="nav nav-tabs" role="tablist">
    <li class="nav-item">
        <a class="nav-link active" data-bs-toggle="tab" href="#tab-discounts">@T("Admin.Promotions.Discounts")</a>
    </li>
    <li class="nav-item">
        <a class="nav-link" data-bs-toggle="tab" href="#tab-apply">@T("Admin.Promotions.ApplyDiscount")</a>
    </li>
    <li class="nav-item">
        <a class="nav-link" data-bs-toggle="tab" href="#tab-products-with-discounts">@T("Admin.Promotions.ProductsWithDiscounts")</a>
    </li>
</ul>

<div class="tab-content mt-4">
    <!-- Tab 1: Existing Discounts -->
    <div id="tab-discounts" class="tab-pane fade show active">
        <partial name="_Grid.Discounts" />
    </div>

    <!-- Tab 2: Apply Discount -->
    <div id="tab-apply" class="tab-pane fade">
        <partial name="_Grid.ApplyDiscount" />
    </div>

    <!-- Tab 3: Products with Discounts -->
    <div id="tab-products-with-discounts" class="tab-pane fade">
        <partial name="_Grid.ProductsWithDiscounts" />
    </div>
</div>

<!-- Modal: Apply Discount -->
<modal id="apply-discount-modal" title="@T("Admin.Promotions.ApplyDiscount.SelectDiscount")">
    <modal-body>
        <select id="selected-discount-id" class="form-control">
            @if (Model.AvailableDiscounts != null)
            {
                foreach (var discount in Model.AvailableDiscounts)
                {
                    <option value="@discount.Id">@discount.Name</option>
                }
            }
        </select>
        <input type="hidden" id="selected-product-ids" />
    </modal-body>
    <modal-footer>
        <button type="button" id="apply-selected-discount-btn" class="btn btn-primary">@T("Admin.Common.Apply")</button>
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">@T("Admin.Common.Cancel")</button>
    </modal-footer>
</modal>