@using Smartstore.Admin.Models.Discounts
@model DiscountProductListModel
@{
    ViewBag.Title = T("Admin.Promotions.Discounts.ApplyToProducts").Value;
}
<style>
    #apply-bulk-discount-modal {
    z-index: 1050 !important;
    pointer-events: auto !important;
}
.modal-backdrop {
    z-index: 1040 !important;
}
</style>
<div class="section-header">
    <div class="title">
        <i class="fa fa-tag"></i>
        <span>@ViewBag.Title</span>
    </div>
    <div class="options">
        <button id="apply-discount" class="btn btn-primary" disabled>
            <i class="fa fa-percentage"></i>
            <span>@T("Admin.Promotions.Discounts.ApplyDiscount")</span>
        </button>
    </div>
</div>

<form id="products-form">
    <div class="table-responsive">
        <table class="table table-hover table-striped" id="products-grid">
            <thead>
                <tr>
                    <th width="40"><input type="checkbox" id="select-all" /></th>
                    <th>@T("Admin.Catalog.Products.Fields.Name")</th>
                    <th>@T("Admin.Catalog.Products.Fields.Sku")</th>
                    <th>@T("Admin.Catalog.Products.Fields.Price")</th>
                    <th>@T("Admin.Catalog.Products.Fields.StockQuantity")</th>
                    <th>@T("Admin.Catalog.Products.Fields.Published")</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var product in Model.Products)
                {
                    <tr>
                        <td><input type="checkbox" name="SelectedProductIds" value="@product.Id" class="product-checkbox" /></td>
                        <td>
                            <a href="@Url.Action("Edit", "Product", new { id = product.Id })">@product.Name</a>
                        </td>
                        <td>@product.Sku</td>
                        <td>@product.Price</td>
                        <td>@product.StockQuantity</td>
                        <td>
                            <i class="fa @(product.Published ? "fa-check" : "fa-times")"></i>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</form>

<partial name="_ApplyDiscountModal" model="new DiscountModel()" />
<script src="~/admin/js/ApplyDiscount.js" asp-append-version="true"></script>
