@using Smartstore.Admin.Models.Discounts
@model DiscountProductModel

<datagrid id="products-grid"
          allow-resize="true"
          allow-row-selection="true"
          preserve-grid-state="true"
          preserve-command-state="true"
          allow-column-reordering="true"
          model-type="Smartstore.Admin.Models.Discounts.DiscountProductModel"> 
    <datasource read="@Url.Action("GetAllProductModels")" />
    <paging position="Bottom" page-index="1" show-size-chooser="true" />
    <sorting allow-unsort="true" allow-multisort="false">
        <sort by="Name" />
    </sorting>
    <columns>
        <column for="Name" hideable="false" />
        <column for="Sku" />
        <column for="Price" />
        <column for="StockQuantity" halign="center" />
        <column for="Published" halign="center" />
    </columns>
</datagrid>
<!-- Modal Overlay -->
<div id="discount-popup-overlay" style="display: none;"></div>

<!-- Modal Dialog -->
<div id="discount-popup-dialog" class="card shadow-sm" style="display: none; max-width: 500px;">
    <div class="card-header bg-secondary text-white d-flex justify-content-between align-items-center">
        <h6 class="mb-0">@T("Admin.Promotions.Discounts.SelectDiscount")</h6>
        <button id="close-discount-popup" class="btn btn-sm btn-close text-white"></button>
    </div>
    <div class="card-body">
        <form id="discount-form" asp-controller="Discount" asp-action="ApplyBulkDiscount" method="post">
            <input type="hidden" id="selected-product-ids" name="SelectedProductIds" />

            <div class="form-group">
                <label for="DiscountId">@T("Admin.Promotions.Discounts.SelectDiscount")</label>
                <select id="DiscountId" name="DiscountId" class="form-control select2-select" required>
                    <option value="">-- @T("Admin.Common.Select") --</option>
                </select>
            </div>

            <div class="form-group mt-3">
                <button type="submit" class="btn btn-primary w-100">
                    <i class="fa fa-check"></i> @T("Admin.Common.Apply")
                </button>
            </div>
        </form>
    </div>
</div>

<!-- Localized messages for JS -->
<span id="no-products-msg" data-msg="@T("Admin.Promotions.Discounts.NoProductsSelected")" style="display:none;"></span>
<span id="error-msg" data-msg="@T("Admin.Common.Error")" style="display:none;"></span>

<script src="~/admin/js/ApplyDiscount.js" asp-append-version="true"></script>

<style>
    #discount-popup-overlay {
        position: fixed;
        top: 0; left: 0; right: 0; bottom: 0;
        background-color: rgba(0, 0, 0, 0.5);
        z-index: 1050;
        display: none;
    }

    #discount-popup-dialog {
        position: fixed;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        z-index: 1060;
        box-shadow: 0 4px 20px rgba(0,0,0,0.3);
        display: none;
    }

    #close-discount-popup {
        background: transparent;
        border: none;
        font-size: 1.2rem;
    }
</style>