@using Smartstore.Admin.Models.Catalog
@model ProductListModel

@{
    ViewBag.Title = "Apply Discount to Products";
}

<div class="section-header">
    <div class="title">
        <i class="fa fa-tag"></i>
        Apply Discount to Products
    </div>
</div>

@{
    var gridViewData = new ViewDataDictionary(this.ViewData);
    gridViewData["Parent"] = Model;
}

<partial name="~/Areas/Admin/Views/Product/Grids/_Grid.Products.cshtml" model="null" view-data="gridViewData" />




<!-- Apply Discount Modal -->
<div class="modal fade" id="apply-discount-modal" 
     tabindex="-1" 
     role="dialog"
     data-apply-url="@Url.Action("ApplyDiscountToProducts", "Discount")">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Apply Discount</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body">
                <label for="discountSelect">Select Discount:</label>
                <select id="discountSelect" class="form-control">
                    @foreach (var discount in Model.AvailableDiscounts)
                    {
                        <option value="@discount.Value">@discount.Text</option>
                    }
                </select>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" onclick="applySelectedDiscount()">Apply Discount</button>
            </div>
        </div>
    </div>
</div>

<script src="~/admin/js/kendo.grid.js" asp-append-version="true"></script>
<script src="~/admin/js/ApplyDiscount.js" asp-append-version="true"></script>

<!-- 3. Add debug logging if needed -->
<script>
    $(function() {
        console.log("Document ready, checking for grid...");
        Smartstore.global.event.subscribe('grid.initialized', function(grid) {
            console.log("Grid initialized:", grid.element.attr("id"));
        });
    });
</script>