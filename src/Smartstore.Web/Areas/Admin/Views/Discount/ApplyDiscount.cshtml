@using Smartstore.Admin.Models.Catalog
@model ProductListModel
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Apply Discount to Products";
}

<div class="content-header">
    <h1>@ViewData["Title"]</h1>
</div>

@await Html.PartialAsync("~/Areas/Admin/Views/Product/Grids/_Grid.Products.cshtml", new ProductOverviewModel(), new ViewDataDictionary(ViewData) { ["Parent"] = Model })

<!-- Apply Discount Modal -->
<div class="modal fade" id="apply-discount-modal" tabindex="-1" role="dialog" aria-labelledby="discountModalLabel" aria-hidden="true">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Apply Discount</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body">
                <label for="discountSelect">Select Discount:</label>
                <select id="discountSelect" class="form-control">
                    @foreach (var discount in Model.AvailableDiscounts)
                    {
                        <option value="@discount.Value">@discount.Text</option>
                    }
                </select>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" onclick="applySelectedDiscount()">Apply Discount</button>
            </div>
        </div>
    </div>
</div>

<script>
    function getSelectedProductIds() {
        return $("#products-grid").data("kendoGrid").selectedKeyNames();
    }

    function applySelectedDiscount() {
        const discountId = $("#discountSelect").val();
        const productIds = getSelectedProductIds();

        if (!productIds.length) {
            alert("Please select at least one product.");
            return;
        }

        $.ajax({
            url: '@Url.Action("ApplyDiscountToProducts", "Discount")',
            method: 'POST',
            traditional: true,
            data: { discountId: discountId, productIds: productIds },
            success: function (response) {
                if (response.success) {
                    alert("Discount applied successfully!");
                    $('#apply-discount-modal').modal('hide');
                } else {
                    alert("Failed to apply discount.");
                }
            },
            error: function () {
                alert("Error while applying discount.");
            }
        });
    }
</script>

<button class="btn btn-success mt-3" data-toggle="modal" data-target="#apply-discount-modal">
    Apply Discount to Selected Products
</button>
