@* @using Smartstore.Admin.Models.Discounts
<datagrid id="apply-discount-grid"
          allow-resize="true"
          allow-row-selection="true"
          preserve-grid-state="true"
          row-checkboxes="true"
          allow-column-reordering="true">

    <datasource read="@Url.Action("GetAllProducts", "Discount")" />
    <paging position="Bottom" show-size-chooser="true" />
    <sorting allow-unsort="true" allow-multisort="false">
        <sort by="Name" />
    </sorting>

    <toolbar>
        <toolbar-group>
            <button id="apply-selected-btn" type="button" class="btn btn-primary btn-flat disabled" disabled>
                <i class="fa fa-tags"></i>
                <span>@T("Admin.Promotions.ApplyDiscount.ApplySelected")</span>
            </button>
        </toolbar-group>
    </toolbar>

    <columns>
        <column for="Id" visible="false" />
        <column title="@T("Admin.Catalog.Products.Fields.Picture")" width="80">
            <display-template>
                <img :src="item.row.PictureUrl" alt="" style="max-width:60px;max-height:60px;" />
            </display-template>
        </column>
        <column for="Name" hideable="false">
            <display-template>
                <a :href="item.row.EditUrl">{{ item.value }}</a>
            </display-template>
        </column>
        <column for="Price" format="{0:F2}" />
    </columns>
</datagrid>

<script suppress-src-include>
    $(document).ready(function () {
        const grid = $('#apply-discount-grid').data('datagrid');

        grid.onRowSelectionChanged(function (rows) {
            const selected = rows.map(r => r.Id);
            const button = $('#apply-selected-btn');

            if (selected.length === 0) {
                button.addClass('disabled').prop('disabled', true);
            } else {
                button.removeClass('disabled').prop('disabled', false);
                button.off('click').on('click', function () {
                    $('#selected-product-ids').val(selected.join(','));
                    $('#apply-discount-modal').modal('show');
                });
            }
        });

        $('#apply-selected-discount-btn').on('click', function () {
            const productIds = $('#selected-product-ids').val();
            const discountId = $('#selected-discount-id').val();

            $.ajax({
                url: '@Url.Action("ApplyDiscountToProducts", "Discount")',
                method: 'POST',
                data: {
                    SelectedProductIds: productIds.split(',').map(Number),
                    SelectedDiscountId: parseInt(discountId)
                },
                success: function (response) {
                    displayNotification(response.message, response.success ? 'success' : 'error');
                    if (response.success) {
                        $('#apply-discount-modal').modal('hide');
                        grid.reload();
                    }
                }
            });
        });
    });
</script> *@